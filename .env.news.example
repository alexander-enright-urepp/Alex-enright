# News Fetcher Environment Variables
# Copy this to .env.news and fill in your actual API keys
# Or set these in your shell environment

# NewsAPI - Get key at https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# GNews - Get key at https://gnews.io
GNEWS_KEY=your_gnews_key_here

# NYTimes - Get key at https://developer.nytimes.com
NYTIMES_KEY=your_nytimes_key_here

# Supabase - Get from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_or_anon_key
